// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}


enum VisibilityEnum {
  PUBLIC
  PRIVATE
  GROUP
}

enum ReactionTypeEnum {
  LIKE
  DISLIKE
  LOVE
  LAUGH
}

enum CommentStatusEnum {
  ACTIVE
  HIDDEN
}

// =====================
// MODELS
// =====================

model User {
  user_id            Int       @id @default(autoincrement())
  firstname          String
  lastname           String
  birth              DateTime
  mail               String    @unique
  password           String
  role               String
  sex                String
  avatar             String?
  bio                String?
  street_number      Int
  street_type        String
  postal_code        Int
  address_complement String
  city               String
  country            String

  resources          Resources[]
  comments           Comments[]
  replies            RepliesComment[]
  groups             CanHave[]
  reactions          React[]
  views              Views[]
}

model GroupRelation {
  relation_id Int     @id @default(autoincrement())
  wording     String

  groups      Group[]
}

model Resources {
  ressource_id Int             @id @default(autoincrement())
  wording      String
  visibility   VisibilityEnum
  user_id      Int

  user         User            @relation(fields: [user_id], references: [user_id])
  comments     Comments[]
  reactions    React[]
  views        Views[]
}

model Comments {
  comment_id   Int               @id @default(autoincrement())
  text         String
  status       CommentStatusEnum
  user_id      Int
  ressource_id Int

  user         User              @relation(fields: [user_id], references: [user_id])
  resource     Resources         @relation(fields: [ressource_id], references: [ressource_id])
  replies      RepliesComment[]
}

model RepliesComment {
  replie_id  Int      @id @default(autoincrement())
  text       String
  user_id    Int
  comment_id Int

  user       User     @relation(fields: [user_id], references: [user_id])
  comment    Comments @relation(fields: [comment_id], references: [comment_id])
}

model Group {
  group_id    Int            @id @default(autoincrement())
  name        String
  relation_id Int

  relation    GroupRelation  @relation(fields: [relation_id], references: [relation_id])
  users       CanHave[]
}

// =====================
// JOIN TABLES
// =====================

model CanHave {
  user_id  Int
  group_id Int

  user     User  @relation(fields: [user_id], references: [user_id])
  group    Group @relation(fields: [group_id], references: [group_id])

  @@id([user_id, group_id])
}

model React {
  user_id       Int
  ressource_id  Int
  reaction_type ReactionTypeEnum?

  user          User       @relation(fields: [user_id], references: [user_id])
  resource      Resources  @relation(fields: [ressource_id], references: [ressource_id])

  @@id([user_id, ressource_id])
}

model Views {
  user_id      Int
  ressource_id Int
  view_number  Int

  user         User       @relation(fields: [user_id], references: [user_id])
  resource     Resources  @relation(fields: [ressource_id], references: [ressource_id])

  @@id([user_id, ressource_id])
}
