# Copier ce fichier en ".env.prod" et renseigner des valeurs réelles.
# ".env.prod" est ignoré par git (voir .gitignore), il ne doit jamais être commit.

# Postgres
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=app_db

# Backend
JWT_SECRET=changeme
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=changeme
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=refreshToken
BCRYPT_SALT_ROUNDS=10
PORT=3000

# URL publique du front (pour CORS) et URL de l'API utilisée par le front au build
CORS_ORIGIN=http://localhost:8080
VITE_API_URL=http://localhost:3000
