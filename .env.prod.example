# Copier ce fichier en ".env.prod" et renseigner des valeurs réelles.
# ".env.prod" est ignoré par git (voir .gitignore), il ne doit jamais être commit.
#
# Docker Compose ne lit les variables ${...} utilisées dans
# docker-compose.prod.yml (POSTGRES_*, VITE_API_URL, etc.) que depuis un
# fichier ".env" à la racine du projet (le "env_file:" du service backend ne
# sert qu'à l'intérieur du conteneur). Une fois ".env.prod" rempli, créer un
# lien symbolique :
#   ln -sf .env.prod .env

# Nom de domaine du serveur (DNS name label Azure) et adresse pour Let's Encrypt
DOMAIN=changeme.switzerlandnorth.cloudapp.azure.com
ACME_EMAIL=changeme@example.com

# Postgres
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=app_db

# Backend
JWT_SECRET=changeme
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=changeme
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=refreshToken
BCRYPT_SALT_ROUNDS=10
PORT=3000

# Avec Traefik, le front et l'API sont servis sur le même port (443) via nginx
# (voir front-web/nginx.conf) : l'appel API se fait en chemin relatif (same-origin).
# CORS_ORIGIN reste défini par cohérence / pour un accès direct au backend.
# Remplacer par le nom de domaine du serveur (https://...), voir DOMAIN ci-dessus.
CORS_ORIGIN=https://changeme.switzerlandnorth.cloudapp.azure.com
VITE_API_URL=
